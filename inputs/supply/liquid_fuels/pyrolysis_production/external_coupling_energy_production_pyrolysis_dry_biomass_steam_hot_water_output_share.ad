- query = UPDATE(OUTPUT_SLOTS(V(energy_production_pyrolysis_dry_biomass), steam_hot_water), conversion, DIVIDE(USER_INPUT(),100.0))
- share_group = energy_production_pyrolysis_dry_biomass_output
- priority = 100
- max_value = 100.0
- min_value = 0.0
- start_value_gql = present:V(energy_production_pyrolysis_dry_biomass, steam_hot_water_output_conversion) * 100.0
- step_value = 0.1
- unit = %
- update_period = future
- coupling_groups = [external_model_liquid_fuels]
