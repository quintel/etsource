- query =
  IF(
    EQUALS(USER_INPUT(), 1.0),
    -> {
      UPDATE(V(energy_heat_heatpump_water_water_electricity, heat_network), subtype, must_run);
      UPDATE(V(energy_heat_heatpump_water_water_electricity, heat_network), group, heatpump_district_heating_curve);
    },
    -> {}
  )
- priority = 0
- max_value = 1.0
- min_value = 0.0
- start_value = 0.0
- step_value = 1.0
- unit = x
- update_period = future
