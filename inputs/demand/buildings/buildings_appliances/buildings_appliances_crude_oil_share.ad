- query =
    UPDATE(
      EDGE(buildings_appliances_crude_oil, buildings_useful_demand_for_appliances),
      share,
      DIVIDE(USER_INPUT(), 100)
    )
- share_group = appliances_buildings
- priority = 0
- max_value = 100.0
- min_value = 0.0
- start_value_gql = present:V(buildings_appliances_crude_oil,share_of_buildings_useful_demand_for_appliances) * 100.0
- step_value = 0.1
- unit = %
- update_period = future
