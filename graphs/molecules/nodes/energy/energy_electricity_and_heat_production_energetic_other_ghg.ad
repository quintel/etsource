# Attribute scaling_exempt set to true to avoid scaling of value read from emissions.csv

- groups = [preset_demand, direct_emissions]
- input.other_ghg = 1.0
- scaling_exempt = true
- use = energetic
- sector_label = energy_electricity_and_heat_production

~ demand = EMISSIONS(energy_electricity_and_heat_production, energetic, other_ghg)
